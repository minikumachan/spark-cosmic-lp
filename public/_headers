/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'

# 注: script/style の 'unsafe-inline' は P0 暫定。
# P4 で inline スクリプト(FOUC/JSON-LD)を sha256 ハッシュ許可に置換し、'unsafe-inline' を排除する
# （静的サイトのため nonce ではなくハッシュ方式。目標: securityheaders.com A+）。

# フォントは長期キャッシュ（ハッシュ無しの固定名のため immutable は付けない）
/fonts/*
  Cache-Control: public, max-age=31536000

# Astro のハッシュ付きアセットは immutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
