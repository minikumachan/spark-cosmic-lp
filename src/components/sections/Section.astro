---
import Container from "../ui/Container.astro";

interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  lead?: string;
  class?: string;
}
const { id, eyebrow, title, lead, class: cls = "" } = Astro.props;
const hasHeader = Boolean(eyebrow || title || lead);
---

<section id={id} class:list={["relative scroll-mt-24 py-24 sm:py-32", cls]}>
  <Container>
    {
      hasHeader && (
        <header class="reveal mb-14 max-w-2xl">
          {eyebrow && (
            <p class="font-mono text-sm uppercase tracking-[0.2em] text-ink">{eyebrow}</p>
          )}
          {title && (
            <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
              {title}
            </h2>
          )}
          {lead && <p class="mt-4 font-body text-lg text-muted">{lead}</p>}
        </header>
      )
    }
    <slot />
  </Container>
</section>
