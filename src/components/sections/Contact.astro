---
import Container from "../ui/Container.astro";
import { site } from "../../lib/content";
const { contact } = site;
const fields = [
  { id: "name", type: "text", ...contact.fields.name },
  { id: "email", type: "email", ...contact.fields.email },
] as const;
---

<section id="contact" class="relative scroll-mt-24 overflow-hidden py-24 sm:py-32">
  <div class="contact-mesh pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>

  <Container>
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="font-mono text-sm uppercase tracking-[0.25em] text-ink">{contact.eyebrow}</p>
        <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
          {contact.title[0]}<br />{contact.title[1]}
        </h2>
        <p class="mt-5 max-w-md font-body text-lg text-muted">{contact.lead}</p>
        <p class="mt-6 font-mono text-sm text-muted">{contact.note}</p>
      </div>

      {/* P4 で react-hook-form + zod + Turnstile + サーバendpoint を実装 */}
      <form class="rounded-card bg-surface p-8 shadow-card ring-1 ring-text/5">
        <div class="space-y-5">
          {
            fields.map((f) => (
              <div>
                <label for={f.id} class="font-body text-sm font-medium">{f.label}</label>
                <input
                  id={f.id}
                  name={f.id}
                  type={f.type}
                  placeholder={f.placeholder}
                  class="mt-2 w-full rounded-2xl bg-bg px-4 py-3 font-body text-text ring-1 ring-text/10 transition-shadow placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-blue"
                />
              </div>
            ))
          }
          <div>
            <label for="message" class="font-body text-sm font-medium">{contact.fields.message.label}</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder={contact.fields.message.placeholder}
              class="mt-2 w-full rounded-2xl bg-bg px-4 py-3 font-body text-text ring-1 ring-text/10 transition-shadow placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-blue"
            ></textarea>
          </div>
        </div>

        <button
          type="submit"
          class="mt-6 w-full rounded-button bg-blue px-6 py-3.5 font-body font-medium text-white shadow-floating transition-transform hover:-translate-y-0.5 motion-reduce:transform-none"
        >
          {contact.submit}
        </button>
      </form>
    </div>
  </Container>
</section>

<style>
  .contact-mesh {
    background:
      radial-gradient(ellipse 50% 60% at 90% 10%, color-mix(in srgb, var(--color-magenta) 14%, transparent), transparent 60%),
      radial-gradient(ellipse 60% 50% at 5% 90%, color-mix(in srgb, var(--color-blue) 14%, transparent), transparent 60%),
      radial-gradient(ellipse 40% 50% at 50% 50%, color-mix(in srgb, var(--color-purple) 8%, transparent), transparent 70%);
  }
</style>
