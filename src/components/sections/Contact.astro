---
import Container from "../ui/Container.astro";
import ContactForm from "./ContactForm.tsx";
import { site } from "../../lib/content";
const { contact } = site;
---

<section id="contact" class="relative scroll-mt-24 overflow-hidden py-24 sm:py-32">
  <div class="contact-bloom pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>

  <Container>
    <div class="grid gap-12 border-t border-hairline pt-12 lg:grid-cols-2 lg:gap-16">
      <div class="reveal">
        <div class="flex items-center gap-4">
          <span class="h-px w-12 bg-text/35"></span>
          <p class="font-mono text-xs uppercase tracking-[0.4em] text-ink">{contact.eyebrow}</p>
        </div>
        <h2 class="mt-6 font-display text-headline font-bold text-text">
          {contact.title[0]}<br /><span class="text-ink">{contact.title[1]}</span>
        </h2>
        <p class="mt-7 max-w-md font-body text-lg leading-[1.85] text-muted">{contact.lead}</p>
        <p class="mt-8 font-mono text-xs uppercase tracking-[0.18em] text-muted">{contact.note}</p>
      </div>

      <div class="reveal lg:pt-2">
        {/* client:idle: 重要な変換フォームの水和を IntersectionObserver に依存させず確実に。
            client:visible は display:contents 島 × 一部ブラウザで IO 未発火の癖がある */}
        <ContactForm client:idle />
      </div>
    </div>
  </Container>
</section>

<style>
  /* editorial 規律: 電撃ブルー主体＋マゼンタを稀な句読点に */
  .contact-bloom {
    background:
      radial-gradient(ellipse 46% 52% at 88% 8%, color-mix(in srgb, var(--color-blue) 13%, transparent), transparent 62%),
      radial-gradient(ellipse 40% 46% at 6% 94%, color-mix(in srgb, var(--color-magenta) 8%, transparent), transparent 60%);
  }
</style>
