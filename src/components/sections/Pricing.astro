---
import { getCollection } from "astro:content";
import Section from "./Section.astro";
import { site } from "../../lib/content";

const pricing = await getCollection("pricing");
const copy = site.sections.pricing;
---

<Section id="pricing" eyebrow={copy.eyebrow} title={copy.title} lead={copy.lead}>
  <div class="@container">
    <ul class="grid grid-cols-1 gap-6 @2xl:grid-cols-3 @2xl:items-center">
      {
        pricing.map((p) => (
          <li
            class:list={[
              "reveal relative flex flex-col rounded-card p-8 shadow-card",
              p.data.featured ? "bg-text text-bg @2xl:py-12" : "bg-surface text-text ring-1 ring-text/5",
            ]}
          >
            {p.data.featured && (
              <span class="absolute right-6 top-6 rounded-button bg-blue px-3 py-1 font-mono text-xs font-medium text-white">
                人気
              </span>
            )}
            <p
              class:list={[
                "font-mono text-xs uppercase tracking-widest",
                p.data.featured ? "text-bg/60" : "text-muted",
              ]}
            >
              {p.data.en}
            </p>
            <h3 class="mt-1 font-display text-2xl font-bold">{p.data.name}</h3>
            <p class="mt-5 font-display text-4xl font-bold tracking-tight">
              {p.data.price}
              <span
                class:list={[
                  "ml-1 font-body text-sm font-normal",
                  p.data.featured ? "text-bg/60" : "text-muted",
                ]}
              >
                {p.data.period}
              </span>
            </p>

            <ul class="mt-7 flex-1 space-y-3">
              {p.data.features.map((f) => (
                <li class="flex items-start gap-3 font-body text-sm">
                  <svg
                    viewBox="0 0 20 20"
                    fill="none"
                    aria-hidden="true"
                    class:list={["mt-0.5 h-4 w-4 shrink-0", p.data.featured ? "text-bg" : "text-blue"]}
                  >
                    <path
                      d="M4.5 10.5l3.2 3.2L15.5 6"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span class:list={[p.data.featured ? "text-bg/85" : "text-text"]}>{f}</span>
                </li>
              ))}
            </ul>

            <a
              href="#contact"
              class:list={[
                "mt-8 block rounded-button px-6 py-3 text-center font-body font-medium transition-transform hover:-translate-y-0.5 motion-reduce:transform-none",
                p.data.featured ? "bg-blue text-white shadow-floating" : "bg-text text-bg",
              ]}
            >
              このプランで相談する
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Section>
