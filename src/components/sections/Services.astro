---
import { getCollection } from "astro:content";
import Section from "./Section.astro";
import Icon from "../ui/Icon.astro";
import { site } from "../../lib/content";
import { accentSoftBg, type Accent } from "../../lib/accent";

const services = await getCollection("services");
const copy = site.sections.services;
---

<Section id="services" index="01" eyebrow={copy.eyebrow} title={copy.title} lead={copy.lead}>
  <div class="@container">
    <ul class="grid grid-cols-1 gap-5 @lg:grid-cols-2 @4xl:grid-cols-4">
      {
        services.map((s) => (
          <li class="reveal group rounded-card bg-surface p-7 shadow-card transition-[transform,box-shadow] duration-300 ease-quint hover:-translate-y-1.5 hover:shadow-floating motion-reduce:transform-none">
            <span
              class:list={[
                "grid h-14 w-14 place-items-center rounded-2xl transition-transform duration-300 group-hover:scale-105 motion-reduce:transform-none",
                accentSoftBg[s.data.accent as Accent],
              ]}
            >
              <Icon name={s.data.icon} size={32} />
            </span>
            <p class="mt-5 font-mono text-xs uppercase tracking-widest text-muted">
              {s.data.en}
            </p>
            <h3 class="mt-1 font-display text-xl font-bold">{s.data.title}</h3>
            <p class="mt-3 font-body text-muted">{s.data.desc}</p>
          </li>
        ))
      }
    </ul>
  </div>
</Section>
