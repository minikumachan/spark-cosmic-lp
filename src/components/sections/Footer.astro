---
import Container from "../ui/Container.astro";
import { site } from "../../lib/content";
import { assetIcon } from "../../lib/assets";
const { footer, brand } = site;
---

<footer class="border-t border-text/10 py-16">
  <Container>
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <a href="#main" class="flex items-center gap-2 font-display text-xl font-bold tracking-tight">
          <img src={assetIcon("icon_logo_spark")} alt="" aria-hidden="true" width="28" height="28" />
          {brand}
        </a>
        <p class="mt-4 max-w-xs font-body text-muted">{footer.tagline}</p>
      </div>

      {
        footer.groups.map((g) => (
          <nav aria-label={g.heading}>
            <p class="font-mono text-xs uppercase tracking-widest text-muted">{g.heading}</p>
            <ul class="mt-4 space-y-2.5">
              {g.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="font-body text-sm text-muted transition-colors hover:text-text"
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <p class="mt-12 border-t border-text/5 pt-8 font-mono text-xs text-muted">
      {footer.copyright}
    </p>
  </Container>
</footer>
