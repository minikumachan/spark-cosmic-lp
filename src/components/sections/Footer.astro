---
import Container from "../ui/Container.astro";
import { site } from "../../lib/content";
import { assetIcon } from "../../lib/assets";
const { footer, brand } = site;
---

<footer class="border-t border-hairline">
  <Container>
    <!-- 編集的タグライン宣言 -->
    <div class="reveal py-16 sm:py-24">
      <p class="max-w-3xl font-display text-headline font-bold tracking-tight text-text">
        {footer.tagline}
      </p>
    </div>

    <div class="grid gap-10 border-t border-hairline py-14 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <a
          href="#main"
          class="inline-flex items-center gap-2 font-display text-2xl font-bold tracking-tight"
        >
          <img src={assetIcon("icon_logo_spark")} alt="" aria-hidden="true" width="28" height="28" />
          {brand}
        </a>
      </div>

      {
        footer.groups.map((g) => (
          <nav aria-label={g.heading}>
            <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">{g.heading}</p>
            <ul class="mt-5 space-y-3">
              {g.links.map((l) => (
                <li>
                  <a href={l.href} class="link-underline font-body text-sm text-muted hover:text-text">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <p class="border-t border-hairline py-8 font-mono text-xs uppercase tracking-[0.18em] text-muted">
      {footer.copyright}
    </p>
  </Container>
</footer>
