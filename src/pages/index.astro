---
import "../styles/fonts.css";
import { getCollection } from "astro:content";
import { site } from "../lib/content";
import DeferredStage from "../components/three/cosmic/DeferredStage.tsx";
import PlanetViewer from "../components/three/cosmic/PlanetViewer.tsx";
import { buildMeta, ORGANIZATION_JSONLD } from "../lib/seo";
const meta = buildMeta({
  title: "ブランドも、体験も、次のステージへ",
  description:
    "spark は、ブランド戦略からデザイン・開発までを一気通貫で手がけるクリエイティブスタジオ。太陽系を旅するインタラクティブな宇宙体験で、あなたのブランドを次のステージへ。",
});
const { hero, contact } = site;
const services = await getCollection("services");
const copy = site.sections.services;
const strengths = await getCollection("strengths");
const scopy = site.sections.strengths;
const works = await getCollection("works");
const wcopy = site.sections.works;
const pricing = await getCollection("pricing");
const pcopy = site.sections.pricing;
const faq = await getCollection("faq");
const fcopy = site.sections.faq;

// FAQPage 構造化データ（リッチリザルト）
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({
    "@type": "Question",
    name: f.data.q,
    acceptedAnswer: { "@type": "Answer", text: f.data.a },
  })),
};

// アクセント名 → コズミック向けの明色（暗背景で映える）
const ACC: Record<string, string> = {
  blue: "#5b8cff",
  cyan: "#4db8ff",
  magenta: "#ff5fb0",
  coral: "#ff7a7e",
  orange: "#ffab4d",
  lime: "#b6e84d",
  green: "#5ed080",
  purple: "#a06bff",
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={meta.canonical} />
    <meta name="theme-color" content="#05060d" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="spark" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.canonical} />
    <meta property="og:image" content={meta.image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={meta.image} />
    <script type="application/ld+json" set:html={JSON.stringify(ORGANIZATION_JSONLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <style>
      :root {
        color-scheme: dark;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
        overflow-x: hidden;
        overflow-x: clip;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
      body {
        background: #05060d;
        color: #eef1ff;
        font-family: "Zen Kaku Gothic New", system-ui, sans-serif;
        overflow-x: hidden;
        overflow-x: clip;
        max-width: 100%;
      }
      /* 永続コズミック背景（固定）。CSS フォールバックも兼ねる */
      .cosmic-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        background:
          radial-gradient(ellipse 60% 50% at 72% 28%, rgba(86, 96, 230, 0.25), transparent 60%),
          radial-gradient(ellipse 50% 55% at 20% 82%, rgba(190, 44, 150, 0.16), transparent 55%),
          radial-gradient(circle at 50% 40%, #0a0c1c, #05060d 75%);
      }
      .skip-link {
        position: fixed;
        top: -100px;
        left: 1rem;
        z-index: 300;
        background: #2f6bff;
        color: #fff;
        padding: 0.7rem 1.2rem;
        border-radius: 0 0 10px 10px;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.8rem;
        text-decoration: none;
        transition: top 0.2s;
      }
      .skip-link:focus {
        top: 0;
      }
      /* 日本語の改行を自然に（禁則処理＋文節区切り。非対応ブラウザは通常折返し） */
      .headline,
      .section-head h2,
      .svc .t,
      .wt,
      .pname,
      .chead,
      .lead {
        line-break: strict;
        word-break: auto-phrase;
      }
      .content {
        position: relative;
        z-index: 1;
        text-shadow: 0 1px 20px rgba(0, 0, 0, 0.6);
      }
      /* 右下FAB群 */
      .fab-group {
        position: fixed;
        right: clamp(1rem, 3vw, 2.2rem);
        bottom: clamp(1rem, 3vw, 2.2rem);
        z-index: 50;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        align-items: flex-end;
      }
      #audio-toggle[aria-pressed="true"] {
        border-color: rgba(127, 178, 255, 0.7);
        background: rgba(47, 107, 255, 0.4);
      }
      .viewer-fab {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(20, 26, 60, 0.6);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(160, 175, 255, 0.3);
        color: #eef1ff;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.78rem;
        letter-spacing: 0.05em;
        padding: 0.7rem 1.2rem;
        border-radius: 999px;
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
        transition:
          transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
          border-color 0.2s,
          background 0.2s;
      }
      .viewer-fab span {
        color: #7fb2ff;
      }
      .viewer-fab:hover {
        transform: translateY(-3px);
        border-color: rgba(127, 178, 255, 0.7);
        background: rgba(30, 40, 90, 0.7);
      }
      /* 入場アニメ（IntersectionObserver で .in 付与・低モーションは即表示） */
      .reveal-up {
        opacity: 0;
        transform: translateY(30px);
        transition:
          opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-up.in {
        opacity: 1;
        transform: none;
      }
      @media (prefers-reduced-motion: reduce) {
        .reveal-up {
          opacity: 1;
          transform: none;
          transition: none;
        }
        html {
          scroll-behavior: auto;
        }
      }
      .wrap {
        width: 100%;
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 clamp(1.5rem, 5vw, 4rem);
      }
      .eyebrow {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #9db4ff;
      }
      .mono {
        font-family: "JetBrains Mono", monospace;
      }
      .display {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
      }
      .accent {
        color: #7fb2ff;
      }

      /* ── HERO ── */
      .hero {
        min-height: 100vh; min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
      }
      /* 見出し裏の局所スクリム（地球位置に依存せず可読性を担保・箱ではない） */
      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background: radial-gradient(
          ellipse 64% 76% at 30% 50%,
          rgba(5, 6, 14, 0.72),
          transparent 70%
        );
      }
      .hero h1 {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 900;
        font-size: clamp(2.6rem, 8vw, 6.5rem);
        line-height: 0.97;
        letter-spacing: -0.03em;
        margin: 1.4rem 0;
        max-width: 18ch;
        text-shadow: 0 4px 60px rgba(0, 0, 0, 0.6);
      }
      .lead {
        max-width: 38ch;
        color: #b9c0e6;
        font-size: clamp(1rem, 1.6vw, 1.2rem);
        line-height: 1.9;
      }
      .cta {
        display: flex;
        flex-wrap: wrap;
        gap: 1.4rem;
        align-items: center;
        margin-top: 2.4rem;
      }
      .btn {
        display: inline-block;
        background: #2f6bff;
        color: #fff;
        font-weight: 700;
        padding: 0.95rem 1.9rem;
        border-radius: 999px;
        text-decoration: none;
        box-shadow: 0 18px 50px rgba(47, 107, 255, 0.4);
        transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      .btn:hover {
        transform: translateY(-2px);
      }
      .ghost {
        color: #cfd6ff;
        text-decoration: none;
        font-weight: 500;
      }
      .ghost:hover {
        color: #fff;
      }
      .stats {
        display: flex;
        gap: 2.6rem;
        margin-top: 3.2rem;
      }
      .stats dt {
        font-family: "Clash Display", sans-serif;
        font-weight: 700;
        font-size: clamp(1.6rem, 3vw, 2.4rem);
      }
      .stats dd {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #8b93c4;
        margin-top: 0.4rem;
      }
      .scrollhint {
        position: absolute;
        bottom: 2.2rem;
        left: 50%;
        transform: translateX(-50%);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.66rem;
        letter-spacing: 0.3em;
        color: #6b7099;
        text-transform: uppercase;
      }

      /* ── card-less section ── */
      .section {
        padding: 14vh 0;
        position: relative;
      }
      /* カード脱却のまま可読性確保：全幅の淡いダークスクリム（箱ではない） */
      .section::before,
      .contact::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        background: linear-gradient(
          180deg,
          transparent 0%,
          rgba(5, 6, 14, 0.6) 14%,
          rgba(5, 6, 14, 0.6) 86%,
          transparent 100%
        );
      }
      .section-head {
        display: flex;
        align-items: baseline;
        gap: 1.2rem;
        border-top: 1px solid rgba(160, 175, 255, 0.16);
        padding-top: 2rem;
        margin-bottom: 3.5rem;
      }
      .section-head .idx {
        font-family: "Clash Display", sans-serif;
        font-weight: 200;
        font-size: clamp(2rem, 5vw, 4rem);
        color: rgba(180, 195, 255, 0.45);
      }
      .section-head h2 {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 800;
        font-size: clamp(1.8rem, 4vw, 3.4rem);
        letter-spacing: -0.02em;
      }
      .section-head .lead {
        margin-left: auto;
        max-width: 34ch;
        padding-bottom: 0.4rem;
        font-size: 0.95rem;
      }
      /* services = card脱却の罫線リスト */
      .svc {
        border-top: 1px solid rgba(160, 175, 255, 0.1);
      }
      .svc li {
        display: grid;
        grid-template-columns: 4rem 1fr 1.4fr;
        gap: 1.5rem;
        align-items: start;
        padding: 2rem 0;
        border-bottom: 1px solid rgba(160, 175, 255, 0.1);
        list-style: none;
        transition: background 0.3s;
      }
      .svc li:hover {
        background: rgba(127, 178, 255, 0.04);
      }
      .svc .n {
        font-family: "JetBrains Mono", monospace;
        color: #7fb2ff;
        font-size: 0.85rem;
        padding-top: 0.4rem;
      }
      .svc .t {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 700;
        font-size: clamp(1.3rem, 2.4vw, 1.9rem);
      }
      .svc .en {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.66rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #8b93c4;
        margin-bottom: 0.5rem;
      }
      .svc .d {
        color: #aab2dc;
        line-height: 1.9;
        padding-top: 0.3rem;
      }
      @media (max-width: 760px) {
        .svc li {
          grid-template-columns: 2.5rem 1fr;
        }
        .svc .d {
          grid-column: 1 / -1;
        }
        .stats {
          flex-wrap: wrap;
          gap: 1.6rem;
        }
      }

      /* ── strengths（特大数値・カード脱却グリッド） ── */
      .strengths {
        min-height: 100vh; min-height: 100dvh;
      }
      .metrics {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 3.5rem 2rem;
      }
      .metric .num {
        font-weight: 800;
        font-size: clamp(3rem, 8vw, 6rem);
        line-height: 1;
        letter-spacing: -0.03em;
        background: linear-gradient(180deg, #ffffff, #8fb6ff);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
      }
      .metric .suf {
        font-size: 0.45em;
        margin-left: 0.12em;
        -webkit-text-fill-color: #7fb2ff;
      }
      .metric .mt {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 700;
        font-size: 1.2rem;
        margin-top: 0.9rem;
      }
      .metric .md {
        color: #aab2dc;
        line-height: 1.8;
        margin-top: 0.6rem;
        font-size: 0.92rem;
      }

      /* グラデ文字のフォールバック（clip非対応で文字が消えるのを防ぐ） */
      @supports not ((-webkit-background-clip: text) or (background-clip: text)) {
        .metric .num {
          background: none;
          -webkit-text-fill-color: #cfe0ff;
          color: #cfe0ff;
        }
      }
      /* キーボードフォーカス可視（全インタラクティブ要素） */
      a:focus-visible,
      button:focus-visible,
      summary:focus-visible,
      input:focus-visible,
      textarea:focus-visible {
        outline: 2px solid #7fb2ff;
        outline-offset: 3px;
        border-radius: 4px;
      }

      /* ── works（罫線リスト・天体ドット） ── */
      .works {
        border-top: 1px solid rgba(160, 175, 255, 0.1);
      }
      .works li {
        display: grid;
        grid-template-columns: 1rem 1fr auto;
        gap: 1.5rem;
        align-items: center;
        padding: 1.7rem 0;
        border-bottom: 1px solid rgba(160, 175, 255, 0.1);
        list-style: none;
        transition:
          background 0.3s,
          padding-left 0.3s;
      }
      .works li:hover {
        background: rgba(127, 178, 255, 0.04);
        padding-left: 0.8rem;
      }
      .wdot {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 50%;
      }
      .wcat {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.66rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #9aa1cb;
        margin-bottom: 0.35rem;
      }
      .wt {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 700;
        font-size: clamp(1.2rem, 2.2vw, 1.7rem);
      }
      .wdesc {
        margin-top: 0.5rem;
        max-width: 46ch;
        font-size: 0.86rem;
        line-height: 1.7;
        color: #aab2dc;
      }
      .wtags {
        display: flex;
        gap: 0.5rem;
        list-style: none;
        flex-wrap: wrap;
      }
      .wtags li {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.66rem;
        color: #aab2dc;
        border: 1px solid rgba(160, 175, 255, 0.2);
        border-radius: 999px;
        padding: 0.25rem 0.7rem;
      }

      /* ── pricing（3つの軌道） ── */
      .plans {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1px;
        background: rgba(160, 175, 255, 0.12);
        border: 1px solid rgba(160, 175, 255, 0.12);
        border-radius: 18px;
        overflow: hidden;
      }
      .plan {
        background: rgba(8, 10, 22, 0.58);
        padding: 2.4rem 2rem;
        display: flex;
        flex-direction: column;
      }
      .plan.featured {
        background: rgba(22, 32, 74, 0.62);
      }
      .pen {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.66rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #9aa1cb;
        display: flex;
        align-items: center;
        gap: 0.7rem;
      }
      .pop {
        background: #2f6bff;
        color: #fff;
        font-size: 0.6rem;
        padding: 0.15rem 0.6rem;
        border-radius: 999px;
      }
      .pname {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0.4rem 0 0.8rem;
      }
      .pprice {
        font-weight: 800;
        font-size: clamp(1.8rem, 3.2vw, 2.6rem);
        letter-spacing: -0.02em;
        white-space: nowrap;
      }
      .pper {
        display: block;
        font-size: 0.5em;
        color: #9aa1cb;
        margin-top: 0.3rem;
        font-weight: 400;
        white-space: normal;
      }
      .pfeat {
        list-style: none;
        margin: 1.6rem 0;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
      }
      .pfeat li {
        color: #c2c9ec;
        font-size: 0.9rem;
        padding-left: 1.4rem;
        position: relative;
      }
      .pfeat li::before {
        content: "✦";
        position: absolute;
        left: 0;
        color: #7fb2ff;
        font-size: 0.75rem;
      }
      .plink {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.8rem;
        color: #7fb2ff;
        text-decoration: none;
      }
      .plink:hover {
        color: #fff;
      }

      /* ── faq（アコーディオン） ── */
      .faq {
        max-width: 820px;
        border-top: 1px solid rgba(160, 175, 255, 0.1);
      }
      .faq details {
        border-bottom: 1px solid rgba(160, 175, 255, 0.1);
      }
      .faq summary {
        cursor: pointer;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        padding: 1.5rem 0;
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 700;
        font-size: clamp(1rem, 1.8vw, 1.25rem);
      }
      .faq summary::-webkit-details-marker {
        display: none;
      }
      .fmark {
        position: relative;
        width: 16px;
        height: 16px;
        flex-shrink: 0;
      }
      .fmark::before,
      .fmark::after {
        content: "";
        position: absolute;
        background: #7fb2ff;
        transition: transform 0.3s;
      }
      .fmark::before {
        top: 7px;
        left: 0;
        width: 16px;
        height: 2px;
      }
      .fmark::after {
        top: 0;
        left: 7px;
        width: 2px;
        height: 16px;
      }
      .faq details[open] .fmark::after {
        transform: scaleY(0);
      }
      .faq details p {
        color: #aab2dc;
        line-height: 1.9;
        padding: 0 0 1.5rem;
        max-width: 60ch;
      }

      /* ── contact grid + form ── */
      .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
      }
      .chead {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 900;
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: 0.98;
        letter-spacing: -0.03em;
        margin-top: 1rem;
      }
      .cnote {
        margin-top: 2rem;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
        color: #9aa1cb;
      }
      .cform {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        position: relative;
      }
      .cform .field {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .cform label {
        font-size: 0.82rem;
        color: #c2c9ec;
        font-weight: 500;
      }
      .cform input,
      .cform textarea {
        background: rgba(10, 14, 30, 0.62);
        border: 1px solid rgba(160, 175, 255, 0.22);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        color: #eef1ff;
        font-family: inherit;
        font-size: 0.95rem;
        transition: border-color 0.2s;
      }
      .cform input::placeholder,
      .cform textarea::placeholder {
        color: #6b7099;
      }
      .cform input:focus,
      .cform textarea:focus {
        outline: none;
        border-color: #7fb2ff;
      }
      .cform .hp {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      .cform .btn {
        margin-top: 0.4rem;
        border: none;
        cursor: pointer;
        font-size: 0.95rem;
      }
      .cform .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .cform-status {
        font-size: 0.85rem;
        min-height: 1.2em;
        color: #aab2dc;
      }
      .cform-status.err {
        color: #ff9b9b;
      }
      .cform-status.ok {
        color: #7fe0a0;
      }
      @media (max-width: 760px) {
        .contact-grid {
          grid-template-columns: 1fr;
          gap: 2.5rem;
        }
        .works li {
          grid-template-columns: 0.8rem 1fr;
        }
        .works .wtags {
          grid-column: 1 / -1;
          padding-left: 0;
        }
      }

      /* ── contact ── */
      .contact {
        min-height: 90vh; min-height: 90dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
      }
      .contact h2 {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 900;
        font-size: clamp(2.4rem, 7vw, 5.5rem);
        line-height: 0.98;
        letter-spacing: -0.03em;
      }
      footer {
        border-top: 1px solid rgba(160, 175, 255, 0.14);
        padding: 3rem 0;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
        color: #8b93c4;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">本文へスキップ</a>
    <div class="cosmic-bg" aria-hidden="true"></div>
    <DeferredStage client:only="react" />
    <PlanetViewer client:idle />

    <!-- 右下FAB群（宇宙の音・惑星図鑑） -->
    <div class="fab-group">
      <button id="audio-toggle" class="viewer-fab" type="button" aria-pressed="false" aria-label="宇宙の環境音を再生">
        <span aria-hidden="true">♪</span> <span class="audio-label">宇宙の音</span>
      </button>
      <button id="viewer-open" class="viewer-fab" type="button" aria-label="惑星鑑賞モードを開く">
        <span aria-hidden="true">✦</span> 惑星図鑑
      </button>
    </div>

    <main id="main" class="content">
      <!-- HERO -->
      <header class="hero">
        <div class="wrap">
          <p class="eyebrow">{hero.eyebrow}</p>
          <h1>{hero.title[0]}<br /><span class="accent">{hero.title[1]}</span></h1>
          <p class="lead">{hero.lead}</p>
          <div class="cta">
            <a class="btn" href={hero.primary.href}>{hero.primary.label}</a>
            <a class="ghost" href={hero.secondary.href}>{hero.secondary.label} →</a>
          </div>
          <dl class="stats">
            {hero.stats.map((s) => (<div><dt class="display">{s.value}</dt><dd>{s.label}</dd></div>))}
          </dl>
        </div>
        <p class="scrollhint">scroll ↓</p>
      </header>

      <!-- SERVICES (01・罫線リスト) -->
      <section id="services" class="section">
        <div class="wrap">
          <div class="section-head reveal-up">
            <span class="idx">01</span>
            <h2>{copy.title}</h2>
            <p class="lead">{copy.lead}</p>
          </div>
          <ul class="svc reveal-up">
            {services.map((s, i) => (
              <li style={`transition-delay:${i * 60}ms`}>
                <span class="n">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <p class="en">{s.data.en}</p>
                  <p class="t">{s.data.title}</p>
                </div>
                <p class="d">{s.data.desc}</p>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- WORKS (02・通過する天体＝罫線リスト) -->
      <section id="works" class="section">
        <div class="wrap">
          <div class="section-head reveal-up">
            <span class="idx">02</span>
            <h2>{wcopy.title}</h2>
            <p class="lead">{wcopy.lead}</p>
          </div>
          <ul class="works reveal-up">
            {works.map((w, i) => (
              <li style={`transition-delay:${i * 50}ms`}>
                <span class="wdot" style={`background:${ACC[w.data.accent]};box-shadow:0 0 18px ${ACC[w.data.accent]}`} />
                <div class="wmain">
                  <p class="wcat">{w.data.category}</p>
                  <p class="wt">{w.data.title}</p>
                  <p class="wdesc">{w.data.desc}</p>
                </div>
                <ul class="wtags">
                  {w.data.tags.map((t) => (
                    <li>{t}</li>
                  ))}
                </ul>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- STRENGTHS (03・銀河接近・特大数値) -->
      <section id="strengths" class="section strengths">
        <div class="wrap">
          <div class="section-head reveal-up">
            <span class="idx">03</span>
            <h2>{scopy.title}</h2>
            <p class="lead">{scopy.lead}</p>
          </div>
          <div class="metrics reveal-up">
            {strengths.map((s, i) => (
              <div class="metric" style={`transition-delay:${i * 60}ms`}>
                <p class="num display">{s.data.metric}<span class="suf">{s.data.suffix}</span></p>
                <p class="mt">{s.data.title}</p>
                <p class="md">{s.data.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- PRICING (04・3つの軌道) -->
      <section id="pricing" class="section">
        <div class="wrap">
          <div class="section-head reveal-up">
            <span class="idx">04</span>
            <h2>{pcopy.title}</h2>
            <p class="lead">{pcopy.lead}</p>
          </div>
          <div class="plans reveal-up">
            {pricing.map((p, i) => (
              <div class:list={["plan", { featured: p.data.featured }]} style={`transition-delay:${i * 70}ms`}>
                <p class="pen">
                  {p.data.en}
                  {p.data.featured && <span class="pop">人気</span>}
                </p>
                <p class="pname">{p.data.name}</p>
                <p class="pprice display">
                  {p.data.price}<span class="pper">{p.data.period}</span>
                </p>
                <ul class="pfeat">
                  {p.data.features.map((f) => (
                    <li>{f}</li>
                  ))}
                </ul>
                <a class="plink" href="#contact">このプランで相談する →</a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- FAQ (05・アコーディオン) -->
      <section id="faq" class="section">
        <div class="wrap">
          <div class="section-head reveal-up">
            <span class="idx">05</span>
            <h2>{fcopy.title}</h2>
            <p class="lead">{fcopy.lead}</p>
          </div>
          <div class="faq reveal-up">
            {faq.map((f) => (
              <details>
                <summary>
                  {f.data.q}
                  <span class="fmark" aria-hidden="true" />
                </summary>
                <p>{f.data.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- CONTACT (06・銀河を背に・実フォーム) -->
      <section id="contact" class="contact">
        <div class="wrap contact-grid">
          <div class="reveal-up">
            <p class="eyebrow">{contact.eyebrow}</p>
            <h2 class="chead">
              {contact.title[0]}<br /><span class="accent">{contact.title[1]}</span>
            </h2>
            <p class="lead" style="margin-top:1.6rem;">{contact.lead}</p>
            <p class="cnote">{contact.note}</p>
          </div>
          <form class="cform reveal-up" id="contact-form" novalidate>
            <div class="field">
              <label for="cf-name">{contact.fields.name.label}</label>
              <input id="cf-name" name="name" type="text" placeholder={contact.fields.name.placeholder} required />
            </div>
            <div class="field">
              <label for="cf-email">{contact.fields.email.label}</label>
              <input id="cf-email" name="email" type="email" placeholder={contact.fields.email.placeholder} required />
            </div>
            <div class="field">
              <label for="cf-msg">{contact.fields.message.label}</label>
              <textarea id="cf-msg" name="message" rows="4" placeholder={contact.fields.message.placeholder} required />
            </div>
            <input type="text" name="company" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
            <button type="submit" class="btn cform-submit">{contact.submit}</button>
            <p class="cform-status" role="status" aria-live="polite" />
          </form>
        </div>
      </section>

      <footer>
        <div class="wrap" style="display:flex;justify-content:space-between;width:100%;flex-wrap:wrap;gap:1rem;">
          <span>© 2026 spark — Creative Studio</span>
          <span>Branding · Strategy · Design · Development</span>
        </div>
      </footer>
    </main>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: "0px 0px -8% 0px" },
      );
      document.querySelectorAll(".reveal-up").forEach((el) => io.observe(el));

      // 惑星鑑賞モードを開く（FAB＋プラン以外でも将来拡張可）
      document.getElementById("viewer-open")?.addEventListener("click", () => {
        window.dispatchEvent(new CustomEvent("cosmic:open-viewer"));
      });

      // 宇宙の環境音（Web Audio で合成・任意ON。ファイル不要・クリックで開始＝自動再生制約に適合）
      const audioBtn = document.getElementById("audio-toggle");
      if (audioBtn) {
        let actx: AudioContext | null = null;
        let master: GainNode | null = null;
        let on = false;
        const AudioCtor = window.AudioContext || (window as unknown as { webkitAudioContext?: typeof AudioContext }).webkitAudioContext;
        const init = () => {
          if (!AudioCtor) return;
          actx = new AudioCtor();
          master = actx.createGain();
          master.gain.value = 0;
          master.connect(actx.destination);
          const filter = actx.createBiquadFilter();
          filter.type = "lowpass";
          filter.frequency.value = 520;
          filter.Q.value = 3;
          filter.connect(master);
          [55, 82.4, 110, 164.8].forEach((f, i) => {
            const o = actx!.createOscillator();
            o.type = i % 2 ? "sine" : "triangle";
            o.frequency.value = f;
            const g = actx!.createGain();
            g.gain.value = 0.1;
            o.connect(g);
            g.connect(filter);
            o.start();
            const lfo = actx!.createOscillator();
            lfo.frequency.value = 0.05 + i * 0.02;
            const lg = actx!.createGain();
            lg.gain.value = 3;
            lfo.connect(lg);
            lg.connect(o.detune);
            lfo.start();
          });
          const fl = actx.createOscillator();
          fl.frequency.value = 0.03;
          const fg = actx.createGain();
          fg.gain.value = 240;
          fl.connect(fg);
          fg.connect(filter.frequency);
          fl.start();
        };
        audioBtn.addEventListener("click", () => {
          if (!actx) init();
          if (!actx || !master) {
            audioBtn.style.display = "none"; // 非対応環境ではボタンを隠す
            return;
          }
          if (actx.state === "suspended") actx.resume();
          on = !on;
          master.gain.linearRampToValueAtTime(on ? 0.42 : 0, actx.currentTime + 1.4);
          audioBtn.setAttribute("aria-pressed", String(on));
          const lbl = audioBtn.querySelector(".audio-label");
          if (lbl) lbl.textContent = on ? "停止" : "宇宙の音";
        });
      }

      // 問い合わせフォーム（/api/contact は Cloudflare Pages Function。dev では未稼働＝本番で動作）
      const form = document.getElementById("contact-form") as HTMLFormElement | null;
      if (form) {
        const mountedAt = Date.now();
        const statusEl = form.querySelector(".cform-status") as HTMLElement;
        const btn = form.querySelector(".cform-submit") as HTMLButtonElement;
        form.addEventListener("submit", async (ev) => {
          ev.preventDefault();
          const data = Object.fromEntries(new FormData(form));
          if (!data.name || !data.email || String(data.message || "").trim().length < 10) {
            statusEl.textContent = "入力をご確認ください（お名前・メール・10文字以上のご相談内容）。";
            statusEl.className = "cform-status err";
            return;
          }
          btn.disabled = true;
          statusEl.className = "cform-status";
          statusEl.textContent = "送信中…";
          try {
            const res = await fetch("/api/contact", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ ...data, _elapsed: Date.now() - mountedAt }),
            });
            if (!res.ok) throw new Error(String(res.status));
            statusEl.textContent = "送信しました。通常2営業日以内にご返信します。";
            statusEl.className = "cform-status ok";
            form.reset();
          } catch {
            statusEl.textContent = "送信に失敗しました。時間をおいて再度お試しください。";
            statusEl.className = "cform-status err";
          } finally {
            btn.disabled = false;
          }
        });
      }
    </script>
  </body>
</html>
