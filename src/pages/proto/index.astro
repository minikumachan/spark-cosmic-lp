---
import "../../styles/fonts.css";
const protos = [
  {
    href: "/proto/galaxy",
    tag: "A",
    name: "深宇宙 × 粒子銀河",
    desc: "GPU粒子 38k の螺旋銀河が差動回転、加算グローで発光。自作GLSL。Shader Particle Art を最前面に。",
    note: "spectacle 優先 ／ 推奨",
  },
  {
    href: "/proto/celestial",
    tag: "B",
    name: "天体中心（Blender）",
    desc: "Blenderで生成したノイズ変位の惑星(GLB)を中央に、フレネル大気リム＋周回粒子 5.2k。Blenderフル活用。",
    note: "object 中心 ／ Blender",
  },
  {
    href: "/proto/light",
    tag: "C",
    name: "軽量・本気",
    desc: "フルスクリーン1パスシェーダで星雲＋星を全部描画。ジオメトリ最小・ポストエフェクト無し。",
    note: "perf 95+ 目標 ／ 最適化",
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>spark — 宇宙プロトタイプ比較</title>
    <style>
      :root {
        color-scheme: dark;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        min-height: 100vh;
        background:
          radial-gradient(ellipse 60% 50% at 75% 20%, rgba(86, 96, 230, 0.22), transparent 60%),
          radial-gradient(ellipse 50% 55% at 20% 85%, rgba(190, 44, 150, 0.16), transparent 55%),
          #05060d;
        color: #f4f2ec;
        font-family: "Zen Kaku Gothic New", system-ui, sans-serif;
        padding: clamp(2rem, 6vw, 6rem);
      }
      .eyebrow {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #9db4ff;
      }
      h1 {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 900;
        font-size: clamp(2.2rem, 6vw, 4.5rem);
        line-height: 1;
        letter-spacing: -0.03em;
        margin: 1rem 0 0.6rem;
      }
      .lead {
        color: #9aa0c4;
        max-width: 60ch;
        line-height: 1.8;
        margin-bottom: 3rem;
      }
      .grid {
        display: grid;
        gap: 1.2rem;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        max-width: 1100px;
      }
      a.card {
        display: block;
        text-decoration: none;
        color: inherit;
        padding: 1.8rem;
        border: 1px solid rgba(160, 170, 255, 0.18);
        border-radius: 16px;
        background: rgba(140, 150, 255, 0.04);
        transition:
          transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
          border-color 0.25s,
          background 0.25s;
      }
      a.card:hover {
        transform: translateY(-4px);
        border-color: rgba(127, 178, 255, 0.6);
        background: rgba(140, 150, 255, 0.08);
      }
      .tag {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.8rem;
        color: #7fb2ff;
        letter-spacing: 0.1em;
      }
      .name {
        font-family: "Clash Display", "Zen Kaku Gothic New", sans-serif;
        font-weight: 700;
        font-size: 1.4rem;
        margin: 0.4rem 0 0.7rem;
      }
      .desc {
        color: #9aa0c4;
        font-size: 0.92rem;
        line-height: 1.7;
      }
      .note {
        margin-top: 1rem;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        color: #8a90b8;
        letter-spacing: 0.06em;
      }
      .hint {
        margin-top: 2.5rem;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
        color: #6b7099;
      }
    </style>
  </head>
  <body>
    <p class="eyebrow">spark · Cosmos prototypes</p>
    <h1>宇宙ベースの見本、3案。</h1>
    <p class="lead">
      実ブラウザで開いて、回転・発光・密度・色みを見比べてください。気に入った方向を選べば、それを軸に全面再設計（カード脱却・全セクションをコズミック化）へ進みます。
    </p>
    <div class="grid">
      {
        protos.map((p) => (
          <a class="card" href={p.href}>
            <span class="tag">{p.tag}</span>
            <div class="name">{p.name}</div>
            <p class="desc">{p.desc}</p>
            <p class="note">{p.note}</p>
          </a>
        ))
      }
    </div>
    <p class="hint">※ 3D は WebGL が要るため実ブラウザでのみ描画されます（ヘッドレス不可）。</p>
  </body>
</html>
